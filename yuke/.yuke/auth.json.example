{
  "version": 1,
  "providers": {
    "minimax": { "type": "api_key_env", "env": "MINIMAX_API_KEY" },
    "openai": {
      "type": "oauth",
      "access_token": "<written by `yuke login openai`>",
      "refresh_token": "<written by `yuke login openai`>",
      "expires_at_ms": 0,
      "account_id": "<chatgpt account id>"
    }
  }
}
